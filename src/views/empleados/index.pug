extends ../layout

block content
  style.
    .container { width: 100%; max-width: 1000px; }
    .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .btn-nuevo { background-color: #50fa7b; color: #282a36; padding: 10px 20px; text-decoration: none; border-radius: 8px; font-weight: bold; }
    .btn-nuevo:hover { background-color: #40c863; }
    .data-table { width: 100%; border-collapse: collapse; background-color: #2a2a40; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
    .data-table th, .data-table td { padding: 15px; text-align: left; border-bottom: 1px solid #44475a; vertical-align: middle; }
    .data-table th { background-color: #44475a; color: #f8f8f2; text-transform: uppercase; font-size: 13px; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover { background-color: #383a59; }
    
    .btn-accion { background-color: #8be9fd; color: #282a36; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 12px; font-weight: bold; margin-right: 5px; display: inline-flex; align-items: center; justify-content: center; height: 28px; border: none; cursor: pointer; font-family: inherit; box-sizing: border-box; }
    .btn-accion:hover { background-color: #6edbf0; }
    .btn-editar { background-color: #bd93f9; color: #f8f8f2; }
    .btn-editar:hover { background-color: #ff79c6; }
    .btn-baja { background-color: #ff5555; color: #f8f8f2; }
    .btn-baja:hover { background-color: #ff2222; }
    
    .badge-activo { background-color: #50fa7b; color: #282a36; padding: 4px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; display: inline-block; }
    .badge-inactivo { background-color: #ff5555; color: #f8f8f2; padding: 4px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; display: inline-block; }

  .container
    .header-flex
      div
        h1= titulo || 'Nómina de Empleados'
        p Gestioná el personal registrado
      div
        a.btn-nuevo(href="/empleados/form") Nuevo Empleado

    table.data-table
      thead
        tr
          th Nombre Completo
          th DNI
          th Empresa ID
          th Estado
          th Acciones
      tbody
        if empleados && empleados.length > 0
          each emp in empleados
            tr
              td= `${emp.nombre} ${emp.apellido}`
              td= emp.dni
              td= emp.empresaId && emp.empresaId.nombre ? emp.empresaId.nombre : emp.empresaId
              td
                if emp.activo
                  span.badge-activo Activo
                else
                  span.badge-inactivo Inactivo
              td
                a.btn-accion(href=`/empleados/${emp.id}`) Ver
                a.btn-accion.btn-editar(href=`/empleados/form/${emp.id}`) Editar
                if emp.activo
                  button.btn-accion.btn-baja(onclick=`darDeBaja(${emp.id})`) Dar de Baja
        else
          tr
            td(colspan="5" style="text-align: center; padding: 30px; color: #6272a4;") No hay empleados registrados en el sistema.

  script.
    async function darDeBaja(id) {
      if (!confirm('¿Dar de baja a este empleado?')) return;
      
      try {
        const response = await fetch(`/api/empleados/${id}`, { method: 'DELETE' });
        
        if (response.ok) {
          // Recarga la página con estado actualizado
          window.location.reload(); 
        } else {
          const errorData = await response.json();
          alert('No se pudo realizar la acción: ' + (errorData.message || 'Verificá el estado del empleado.'));
        }
      } catch (error) {
        console.error(error);
        alert('Error de conexión con el servidor al intentar dar de baja.');
      }
    }
