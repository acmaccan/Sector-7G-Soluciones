extends ../layout


block content
  style.
    .form-container {
      background: #2a2a40;
      padding: 40px;
      border-radius: 12px;
      width: 100%;
      max-width: 400px;
    }
    h1 {
      margin-bottom: 24px;
      color: #bd93f9;
      text-align: center;
    }
    .form-group {
      margin-bottom: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    label {
      font-size: 0.9rem;
      color: #ccc;
    }
    input {
      padding: 10px;
      border-radius: 6px;
      border: 1px solid #444;
      background: #1e1e2f;
      color: #fff;
      font-size: 1rem;
    }
    input:focus {
      outline: none;
      border-color: #bd93f9;
    }
    button {
      width: 100%;
      padding: 12px;
      background: #bd93f9;
      color: #1e1e2f;
      border: none;
      border-radius: 6px;
      font-size: 1rem;
      font-weight: bold;
      cursor: pointer;
      margin-top: 8px;
    }
    button:hover {
      background: #ff79c6;
    }
    .error-msg {
      background: #ff5555;
      color: white;
      padding: 10px 14px;
      border-radius: 6px;
      margin-bottom: 16px;
      font-size: 0.9rem;
    }

  .form-container
    h1 Iniciar sesión

    if error
      .error-msg= error

    form(action="/login" method="POST")
      .form-group
        label(for="usuario") Usuario
        input#usuario(type="text" name="usuario" placeholder="Nombre de usuario" required autofocus)

      .form-group
        label(for="password") Contraseña
        input#password(type="password" name="password" placeholder="Contraseña" required)

      button(type="submit") Ingresar