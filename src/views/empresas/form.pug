extends ../layout

block content

  .container-form
    a.btn-volver(href="/empresas") Cancelar y volver

    .card-form
      //- Cambiar el título de acuerdo a la empresa
      h1= empresa ? 'Editar Empresa' : 'Nueva Empresa'

      form#empresaForm
        .form-group
          label(for="nombre") Razón Social / Nombre:
          input#nombre.form-control(type="text", name="nombre", value=empresa ? empresa.nombre : '', required)
        
        .form-group
          label(for="cuit") CUIT:
          input#cuit.form-control(type="text", name="cuit", value=empresa ? empresa.cuit : '', required)
        
        .form-group
          label(for="rubro") Rubro:
          input#rubro.form-control(type="text", name="rubro", value=empresa ? empresa.rubro : '', required)
        
        .form-group
          label(for="contacto") Contacto (Email o Teléfono):
          input#contacto.form-control(type="text", name="contacto", value=empresa ? empresa.contacto : '', required)

        .form-group
          label(for="convenio") Convenio:
          select#convenio.form-control(name="convenio")
            option(value="general" selected=(!empresa || empresa.convenio === 'general')) General
            option(value="docente" selected=(empresa && empresa.convenio === 'docente')) Docente
            option(value="sanidad" selected=(empresa && empresa.convenio === 'sanidad')) Sanidad
            option(value="comercio" selected=(empresa && empresa.convenio === 'comercio')) Comercio
            option(value="otro" selected=(empresa && empresa.convenio === 'otro')) Otro

        .form-group
          label(for="fechaCierrePeriodo") Fecha cierre período (1 a 28):
          input#fechaCierrePeriodo.form-control(type="number", min="1", max="28", name="fechaCierrePeriodo", value=empresa ? empresa.fechaCierrePeriodo : '')

        button.btn-guardar(type="submit")= empresa ? 'Guardar Cambios' : 'Registrar Empresa'

  //- Lógica de cliente para enviar los datos
  script.
    document.getElementById('empresaForm').addEventListener('submit', async (e) => {
      e.preventDefault(); // Evita que la página se recargue

 
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());
      
      // Variables de Pug a JavaScript para saber si creamos o editamos
      const isEdit = #{empresa ? 'true' : 'false'};
      const empresaId = '#{empresa ? empresa.id : ""}';
      
      const url = isEdit ? `/api/empresas/${empresaId}` : '/api/empresas';
      const method = isEdit ? 'PUT' : 'POST';

      try {
        const response = await fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (response.ok) {
 
          window.location.href = '/empresas';
        } else {
          const errorData = await response.json();
          alert('Error: ' + (errorData.message || 'No se pudo guardar la empresa'));
        }
      } catch (error) {
        console.error(error);
        alert('Ocurrió un error de red al intentar guardar.');
      }
    });
