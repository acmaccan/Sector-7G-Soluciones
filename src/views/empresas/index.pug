extends ../layout

block content

  .container
    .header-flex
      div
        h1= titulo || 'Directorio de Empresas'
        p Gestioná las empresas clientes registradas en el sistema.
      div
        a.btn-nuevo(href="/empresas/form") + Nueva Empresa

    table.data-table
      thead
        tr
          th Nombre
          th CUIT
          th Rubro
          th Contacto
          th Estado
          th Acciones
      tbody
        if empresas && empresas.length > 0
          each emp in empresas
            tr
              td= emp.nombre
              td= emp.cuit
              td= emp.rubro
              td= emp.contacto
              td
                if emp.activo
                  span.badge-activo Activo
                else
                  span.badge-inactivo Inactivo
              td
                a.btn-accion(href=`/empresas/${emp.id}`) Ver
                a.btn-accion(href=`/empresas/form/${emp.id}`) Editar
        else
          tr
            td(colspan="6" style="text-align: center; padding: 30px; color: #6272a4;") No hay empresas registradas actualmente.