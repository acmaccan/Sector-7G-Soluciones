extends ../layout

block content


  .container
    a.btn-volver(href="/seguimientos") ← Volver a Seguimientos

    .card-detalle
      h1= `Seguimiento - #${(seguimiento._id || seguimiento.id).toString().substring(0,8)}...`
      
      .info-grid
        .info-item
          .info-label Responsable / Estado
          .info-valor= seguimiento.responsable || seguimiento.estado
        
        .info-item
          .info-label Fecha de Comentario
          .info-valor= seguimiento.fecha
          
        .info-item
          .info-label Novedad Relacionada
          .info-valor
            if seguimiento.novedad
              a(href=`/novedades/${seguimiento.novedad.id}` style="color: #ff79c6; text-decoration: none; font-weight: bold;")= seguimiento.novedad.tipo
              span.text-muted= ` (${seguimiento.novedad.estado})`
            else
              span N/A
              
        .info-item
          .info-label Empleado / Empresa
          .info-valor
            if seguimiento.empleado
              span= `${seguimiento.empleado.nombre} ${seguimiento.empleado.apellido}`
            else
              span N/A
            if seguimiento.empresa
              span.text-muted= ` @ ${seguimiento.empresa.nombre}`
              
        .info-item
          .info-label Estado
          .info-valor
            if seguimiento.activo
              span.badge-activo Activo
            else
              span.badge-inactivo Inactivo (Eliminado)
              
        .info-item.full-width
          .info-label Comentario / Observación
          .info-valor(style="white-space: pre-wrap;")= seguimiento.comentario || seguimiento.observacion
