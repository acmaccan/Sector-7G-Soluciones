extends ../layout

block content
  .container
    h1= titulo
    #errorMsg(style="display:none; background:#c0392b; color:white; padding:12px 16px; border-radius:8px; margin-bottom:16px; max-width:600px;") 
    form(id="seguimientoForm" style="max-width: 600px; background: #2a2a40; padding: 30px; border-radius: 12px;")
      input(type="hidden" name="id" value=seguimiento ? (seguimiento._id || seguimiento.id) : "")
      
      .form-group(style="margin-bottom: 20px;")
        label Novedad Relacionada:
        select(name="novedadId" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white;")
          option(value="") Seleccione una novedad...
          each nov in novedades
            option(value=(nov._id || nov.id) selected=(seguimiento && String(seguimiento.novedadId._id || seguimiento.novedadId) === String(nov._id || nov.id)))= `Nov #${(nov._id || nov.id).toString().substring(0,8)}... - ${nov.tipo} (${nov.empleado ? `${nov.empleado.nombre} ${nov.empleado.apellido}` : 'N/A'})`

      .form-group(style="margin-bottom: 20px;")
        label Responsable:
        input(type="text" name="responsable" value=seguimiento ? (seguimiento.responsable || seguimiento.estado) : "" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white;")

      .form-group(style="margin-bottom: 20px;")
        label Fecha:
        input(type="date" name="fecha" value=seguimiento ? seguimiento.fecha : "" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white;")

      .form-group(style="margin-bottom: 20px;")
        label Comentario / Acción:
        textarea(name="comentario" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white; height: 100px;")= seguimiento ? (seguimiento.comentario || seguimiento.observacion) : ""

      button.btn-nuevo(type="submit" style="width: 100%; border: none;") Guardar Seguimiento

  script.
    document.getElementById('seguimientoForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorMsg = document.getElementById('errorMsg');
      errorMsg.style.display = 'none';
      const btn = e.target.querySelector('button[type=submit]');
      btn.disabled = true;
      btn.textContent = 'Guardando...';
      const formData = Object.fromEntries(new FormData(e.target));
      const id = formData.id;
      const method = id ? 'PUT' : 'POST';
      const url = id ? `/api/seguimientos/${id}` : '/api/seguimientos';
      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });
        if (res.ok) { 
          window.location.href = '/seguimientos'; 
        } else {
          const errorData = await res.json().catch(() => ({}));
          errorMsg.textContent = '⚠️ ' + (errorData.message || 'No se pudo guardar el seguimiento.');
          errorMsg.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Guardar Seguimiento';
        }
      } catch(err) {
        errorMsg.textContent = '⚠️ Error de red: ' + err.message;
        errorMsg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Guardar Seguimiento';
      }
    });
