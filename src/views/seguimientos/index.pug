extends ../layout

block content
  .container
    .header-flex
      div
        h1= titulo
        p Historial de acciones y comentarios sobre las novedades.
      a.btn-nuevo(href="/seguimientos/form") + Agregar Comentario

    table.data-table
      thead
        tr
          th ID
          th Novedad Relacionada
          th Empleado / Empresa
          th Fecha
          th Responsable / Estado
          th Comentario / Observación
          th Acciones
      tbody
        if seguimientos && seguimientos.length > 0
          each seg in seguimientos
            tr
              td(style="font-family: monospace; font-size: 11px; max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;")= seg._id || seg.id
              td
                if seg.novedad
                  a(href=`/novedades/${seg.novedad.id}` style="color: #ff79c6; text-decoration: none; font-weight: bold;")= seg.novedad.tipo
                  br
                  span.text-muted= `Estado: ${seg.novedad.estado}`
                else
                  span N/A
              td
                if seg.empleado
                  span= `${seg.empleado.nombre} ${seg.empleado.apellido}`
                else
                  span N/A
                if seg.empresa
                  br
                  span.text-muted= seg.empresa.nombre
              td= seg.fecha
              td= seg.responsable || seg.estado
              td= seg.comentario || seg.observacion
              td.td-acciones
                a.btn-accion(href=`/seguimientos/${seg._id || seg.id}`) Ver
                if seg.activo
                  button.btn-accion.btn-baja.js-baja(type="button" data-id=seg._id || seg.id) Eliminar
        else
          tr
            td(colspan="7" style="text-align: center; padding: 30px; color: #6272a4;") No se encontraron seguimientos registrados.

  script.
    async function darDeBaja(id) {
      if (!confirm('¿Dar de baja a este seguimiento?')) return;
      
      try {
        const response = await fetch(`/api/seguimientos/${id}`, { method: 'DELETE' });
        
        if (response.ok) {
          window.location.reload(); 
        } else {
          const errorData = await response.json().catch(() => ({}));
          alert('No se pudo realizar la acción: ' + (errorData.message || `HTTP ${response.status}`));
        }
      } catch (error) {
        console.error(error);
        alert('Error de conexión con el servidor.');
      }
    }

    document.addEventListener('click', (event) => {
      const btn = event.target.closest('button.js-baja');
      if (!btn) return;
      const id = btn.getAttribute('data-id');
      darDeBaja(id);
    });
