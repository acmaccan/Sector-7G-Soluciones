doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo || 'Talento Evolutivo S.A.'
    style.
 
      body { 
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
        background-color: #1e1e2f; 
        color: #ffffff; 
        margin: 0; 
      }
      header {
        background-color: #2a2a40;
        padding: 15px 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
      }

block content
  style.
    .session-panel {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 12px;
      width: 100%;
      max-width: 1200px;
      margin: 20px auto;
    }
    .session-user {
      color: #8be9fd;
      font-weight: bold;
    }
    .session-logout {
      background: none;
      border: 1px solid #ff79c6;
      color: #ff79c6;
      font-weight: bold;
      cursor: pointer;
      font-size: 0.95rem;
      padding: 6px 12px;
      border-radius: 6px;
    }
    .session-logout:hover {
      background-color: rgba(255, 121, 198, 0.12);
    }
    .dashboard-header { text-align: center; margin-bottom: 40px; }
    .dashboard-header h1 { color: #50fa7b; font-size: 2.5em; margin-bottom: 10px; }
    .dashboard-header p { color: #6272a4; font-size: 1.1em; }
    

    .grid-container {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 25px;
      padding: 20px 0;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .module-card {
      background-color: #2a2a40;
      border-radius: 12px;
      padding: 25px;
      text-align: center;
      box-shadow: 0 4px 15px rgba(0,0,0,0.2);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border-top: 4px solid #bd93f9;
      display: flex;
      flex-direction: column;
    }
    
    .module-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.4);
      border-top-color: #ff79c6;
    }
    
    .module-card h2 { color: #f8f8f2; margin-top: 0; font-size: 1.4em; }
    .module-card p { color: #8be9fd; font-size: 0.9em; flex-grow: 1; margin-bottom: 20px; line-height: 1.4; }
    
    .btn-ingresar {
      background-color: #44475a;
      color: #f8f8f2;
      text-decoration: none;
      padding: 10px 15px;
      border-radius: 6px;
      font-weight: bold;
      transition: background-color 0.2s;
    }
    .btn-ingresar:hover { background-color: #6272a4; color: #50fa7b; }

  if usuarioSesion
    .session-panel
      span.session-user= `Usuario: ${usuarioSesion.usuario}`
      form(action="/logout" method="POST" style="margin:0")
        button.session-logout(type="submit") Salir

  .dashboard-header
    h1 Talento Evolutivo S.A.
    p Panel de Control Principal - Seleccioná un módulo para operar

  .grid-container

    .module-card
      h2 Empresas
      p Gestión de clientes, rubros y estado de cuentas.
      a.btn-ingresar(href="/empresas") Ingresar
    
    .module-card
      h2 Empleados
      p Directorio de personal, datos de contacto y asignaciones.
      a.btn-ingresar(href="/empleados") Ingresar
      
    .module-card
      h2 Novedades
      p Carga de novedades con filtros y seguimientos detallados.
      a.btn-ingresar(href="/novedades") Ingresar
      
    .module-card
      h2 Seguimiento
      p Control y bitácora de estados de trámites y procesos.
      a.btn-ingresar(href="/seguimientos") Ingresar
      
    .module-card
      h2 Liquidaciones
      p Cálculo de haberes, recibos y detalles de liquidación.
      a.btn-ingresar(href="/liquidaciones") Ingresar
      
    .module-card
      h2 Socios
      p Administración del directorio de socios y participaciones.
      a.btn-ingresar(href="/socios") Ingresar

    .module-card
      h2 Reportes
      p Indicadores clave, resúmenes y tablas de impacto visual.
      a.btn-ingresar(href="/resumen") Ingresar  

    .module-card
      h2 Auditoría
      p Registro histórico de acciones y trazabilidad del sistema.
      a.btn-ingresar(href="/auditoria") Ingresar
