doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo || 'Talento Evolutivo S.A.'
    style.
      /* Estilos base compartidos*/
      body { 
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
        background-color: #1e1e2f; 
        color: #ffffff; 
        margin: 0; 
      }
      header {
        background-color: #2a2a40;
        padding: 15px 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
      }
      nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 20px;
        justify-content: center;
      }
      .header-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }
      .session-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        white-space: nowrap;
      }
      .session-user {
        color: #8be9fd;
        font-weight: bold;
      }
      .logout-button {
        background: none;
        border: 1px solid #ff79c6;
        color: #ff79c6;
        font-weight: bold;
        cursor: pointer;
        font-size: 0.95rem;
        padding: 6px 12px;
        border-radius: 6px;
      }
      .logout-button:hover {
        background-color: rgba(255, 121, 198, 0.12);
      }
      nav a {
        color: #ff79c6;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.3s;
      }
      nav a:hover {
        color: #bd93f9;
      }
      main {
        padding: 40px;
        display: flex;
        justify-content: center;
      }
  body
    header
      nav
        ul
            li: a(href="/index") Inicio
            li: a(href="/empresas") Empresas
            li: a(href="/empleados") Empleados
            li: a(href="/liquidaciones") Liquidaciones
            li: a(href="/socios") Socios
            li: a(href="#") Novedades
            li: a(href="#") Seguimientos
            li: a(href="/resumen") Reportes
            li: a(href="#") Auditoría
      .header-bar
        nav
          ul
            if usuarioSesion
              li: a(href="/index") Inicio
              li: a(href="/empresas") Empresas
              li: a(href="/empleados") Empleados
              li: a(href="/liquidaciones") Liquidaciones
              li: a(href="/socios") Socios
              li: a(href="/novedades") Novedades
              li: a(href="/seguimientos") Seguimientos
              li: a(href="/resumen") Reportes
              li: a(href="/auditoria") Auditoría
        if usuarioSesion
          .session-actions
            span.session-user= `Usuario: ${usuarioSesion.usuario}`
            form(action="/logout" method="POST" style="margin:0")
              button.logout-button(type="submit") Salir
    main
      //- Contenido 
      block content