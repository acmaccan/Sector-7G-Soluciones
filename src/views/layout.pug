doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo || 'Talento Evolutivo S.A.'
    link(rel="stylesheet", href="/css/styles.css")
    
    
  body
    header
      .header-bar
        nav
          ul
            if usuarioSesion
              each mod in modulesByRole
                li: a(href=mod.ruta)= mod.nombre
        if usuarioSesion
          .session-actions
            span.session-user= `Usuario: ${usuarioSesion.usuario}`
            form(action="/logout" method="POST" style="margin:0")
              button.logout-button(type="submit") Salir
    main
      block content