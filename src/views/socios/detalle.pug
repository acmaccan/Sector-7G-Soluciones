extends ../layout

block content
  style.
    .container { width: 100%; max-width: 800px; margin: 0 auto; }
    .card { background-color: #2a2a40; border-radius: 10px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
    .header-flex { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #44475a; padding-bottom: 20px; margin-bottom: 20px; }
    .header-flex h1 { color: #50fa7b; margin: 0; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .btn-volver { display: inline-block; background-color: #44475a; color: #f8f8f2; padding: 10px 20px; text-decoration: none; border-radius: 6px; font-weight: bold; margin-top: 30px; }
    .btn-volver:hover { background-color: #6272a4; }
    .badge-activo { background-color: #50fa7b; color: #282a36; padding: 5px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }
    .badge-inactivo { background-color: #ff5555; color: #f8f8f2; padding: 5px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }

  .container
    .card
      .header-flex
        h1= titulo
        if socio.activo
          span.badge-activo Activo
        else
          span.badge-inactivo Inactivo
          
      .info-grid
        .info-group
          label Nombre Completo / Razón Social
          p= socio.apellido ? `${socio.nombre} ${socio.apellido}` : socio.nombre
        .info-group
          label DNI / CUIT
          p= socio.dni || socio.cuit || 'No registrado'
        .info-group
          label Correo Electrónico
          p= socio.email
        .info-group
          label Nivel de Participación
          p= `${socio.participacion}%`
        .info-group
          label Fecha de Ingreso
          p= socio.fechaIngreso
          
      a.btn-volver(href="/socios") Volver al listado