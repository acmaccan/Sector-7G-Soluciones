extends ../layout

block content

  .container
    .header-flex
      div
        h1= titulo || 'Directorio de Socios'
        p Gestion de socios
      div
        a.btn-nuevo(href="/socios/form") Nuevo Socio

    table.data-table
      thead
        tr
          th Nombre / Razón Social
          th CUIT / DNI
          th Correo Electrónico
          th Estado
          th Acciones
          
      tbody
        if socios && socios.length > 0
          each socio in socios
            tr
              td= socio.apellido ? `${socio.nombre} ${socio.apellido}` : socio.nombre
              td= socio.cuit || socio.dni || 'Sin registro'
              td= socio.email || 'Sin registro'
              td
                if socio.activo
                  span.badge-activo Activo
                else
                  span.badge-inactivo Inactivo
              td
                a.btn-accion(href=`/socios/${socio._id}`) Ver
                a.btn-accion.btn-editar(href=`/socios/form/${socio._id}`) Editar
                if socio.activo
                  button.btn-accion.btn-baja(onclick=`darDeBaja('${socio._id}')`) Dar de Baja
        else
          tr
            td(colspan="5" style="text-align: center; padding: 30px; color: #6272a4;") No hay socios registrados en el sistema.

  script.
    async function darDeBaja(id) {
      if (!confirm('¿Dar de baja a este socio?')) return;
      
      try {
        const response = await fetch(`/api/socios/${id}`, { method: 'DELETE' });
        
        if (response.ok) {
          window.location.reload(); 
        } else {
          const errorData = await response.json();
          alert('No se pudo realizar la acción: ' + (errorData.message || 'Verificá el estado del socio.'));
        }
      } catch (error) {
        console.error(error);
        alert('Error de conexión con el servidor al intentar dar de baja.');
      }
    }
