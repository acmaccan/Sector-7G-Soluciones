extends ../layout

block content
  .container
    h1= titulo
    #errorMsg(style="display:none; background:#c0392b; color:white; padding:12px 16px; border-radius:8px; margin-bottom:16px; max-width:600px;") 
    form(id="novedadForm" style="max-width: 600px; background: #2a2a40; padding: 30px; border-radius: 12px;")
      input(type="hidden" name="id" value=novedad ? (novedad._id || novedad.id) : "")
      
      .form-group(style="margin-bottom: 15px;")
        label Tipo de Novedad:
        select(name="tipo" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white;")
          option(value="Licencia Medica" selected=(novedad && novedad.tipo == 'Licencia Medica')) Licencia Médica
          option(value="Accidente Trabajo" selected=(novedad && novedad.tipo == 'Accidente Trabajo')) Accidente de Trabajo
          option(value="Sancion" selected=(novedad && novedad.tipo == 'Sancion')) Sanción Disciplinaria

      .form-group(style="margin-bottom: 15px;")
        label Empresa:
        select(name="empresaId" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white;")
          option(value="") Seleccione una empresa...
          each emp in empresas
            option(value=emp.id selected=(novedad && String(novedad.empresaId._id || novedad.empresaId) === String(emp.id)))= emp.nombre

      .form-group(style="margin-bottom: 15px;")
        label Empleado:
        select(name="empleadoId" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white;")
          option(value="") Seleccione un empleado...
          each emp in empleados
            option(value=emp.id selected=(novedad && String(novedad.empleadoId._id || novedad.empleadoId) === String(emp.id)))= `${emp.nombre} ${emp.apellido}`

      .form-group(style="margin-bottom: 15px;")
        label Fecha (YYYY-MM-DD):
        input(type="date" name="fecha" value=novedad ? novedad.fecha : "" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white;")

      .form-group(style="margin-bottom: 15px;")
        label Estado (Opcional):
        select(name="estado" style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white;")
          option(value="pendiente" selected=(novedad && novedad.estado === 'pendiente')) Pendiente
          option(value="procesada" selected=(novedad && novedad.estado === 'procesada')) Procesada
          option(value="rechazada" selected=(novedad && novedad.estado === 'rechazada')) Rechazada

      .form-group(style="margin-bottom: 20px;")
        label Descripción:
        textarea(name="descripcion" required style="width: 100%; padding: 10px; border-radius: 6px; background: #44475a; color: white; height: 100px;")= novedad ? novedad.descripcion : ""

      button.btn-nuevo(type="submit" style="width: 100%; border: none;")= novedad ? 'Guardar Cambios' : 'Crear Novedad'

  script.
    document.getElementById('novedadForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorMsg = document.getElementById('errorMsg');
      errorMsg.style.display = 'none';
      const btn = e.target.querySelector('button[type=submit]');
      btn.disabled = true;
      btn.textContent = 'Guardando...';
      const formData = Object.fromEntries(new FormData(e.target));
      const id = formData.id;
      const method = id ? 'PUT' : 'POST';
      const url = id ? `/api/novedades/${id}` : '/api/novedades';
      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });
        if (res.ok) { 
          window.location.href = '/novedades'; 
        } else {
          const errorData = await res.json().catch(() => ({}));
          errorMsg.textContent = '⚠️ ' + (errorData.message || 'No se pudo guardar la novedad.');
          errorMsg.style.display = 'block';
          btn.disabled = false;
          btn.textContent = id ? 'Guardar Cambios' : 'Crear Novedad';
        }
      } catch(err) {
        errorMsg.textContent = '⚠️ Error de red: ' + err.message;
        errorMsg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = id ? 'Guardar Cambios' : 'Crear Novedad';
      }
    });
